# ============================================================
# Medicare Pro - Environment Configuration
# Copiar a .env y configurar valores reales
# ============================================================

# ------------------------------------------------------------
# AMBIENTE
# ------------------------------------------------------------
MEDICARE_ENV=development
# Opciones: development, testing, production

# ------------------------------------------------------------
# SEGURIDAD
# ------------------------------------------------------------
SECRET_KEY=change-this-to-a-secure-random-key-in-production
PASSWORD_SALT=another-random-salt-value

# ------------------------------------------------------------
# BASE DE DATOS
# ------------------------------------------------------------
# PostgreSQL (producción/desarrollo)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medicare_pro

# Supabase (opcional - para cloud)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# ------------------------------------------------------------
# REDIS (Caché Distribuida)
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------
# NEXTGEN API
# ------------------------------------------------------------
NEXTGEN_API_URL=http://localhost:8000
NEXTGEN_API_KEY=your-api-key
ENABLE_NEXTGEN_API=false

# ------------------------------------------------------------
# EMAIL / SMTP
# ------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@medicare.local

# ------------------------------------------------------------
# IA / ML (Opcional)
# ------------------------------------------------------------
LLM_PROVIDER=none
# Opciones: openai, anthropic, local, none
LLM_API_KEY=your-llm-api-key
LLM_MODEL=gpt-4
LOCAL_LLM_URL=http://localhost:11434

# ------------------------------------------------------------
# AUDITORÍA Y COMPLIANCE
# ------------------------------------------------------------
AUDIT_SECRET_KEY=secure-audit-trail-key
ENABLE_AUDIT_LOG=true

# ------------------------------------------------------------
# MONITOREO
# ------------------------------------------------------------
SENTRY_DSN=https://your-sentry-dsn
METRICS_ENABLED=false

# ------------------------------------------------------------
# DESARROLLO / DEBUG
# ------------------------------------------------------------
DEBUG=true
LOG_LEVEL=DEBUG
# Opciones: DEBUG, INFO, WARNING, ERROR

# ------------------------------------------------------------
# CI/CD
# ------------------------------------------------------------
GITHUB_TOKEN=your-github-token
CODECOV_TOKEN=your-codecov-token
