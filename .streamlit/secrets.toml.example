# Copia a secrets.toml (local) o pega el contenido en Streamlit Cloud -> App -> Settings -> Secrets.
# No subas secrets.toml al repo: contiene credenciales reales y esta en .gitignore.

SUPABASE_URL = "https://tu-proyecto.supabase.co"
SUPABASE_KEY = "tu_clave_supabase"

# Dominio publico HTTPS de la app principal, sin barra final.
SITE_URL = "https://tudominio.streamlit.app"

# URL publica o local del modulo Medicare Billing Pro mostrado en la landing/publicidad.
BILLING_APP_URL = "https://tu-medicare-billing-pro.streamlit.app"

# Opcional: linea extra de aviso en la franja superior.
# MC_AVISO_SISTEMA_EXTRA = "Mantenimiento programado domingo 22:00."

# Opcional: limite de sesion en minutos (15-720, default 480 = 8h).
SESSION_TIMEOUT_MINUTES = 480

# Opcional: proteccion contra fuerza bruta (0 = desactivado).
MAX_LOGIN_ATTEMPTS = 5
LOGIN_LOCKOUT_SECONDS = 300
LOGIN_LOCKOUT_PERSIST = "session"  # session | file | supabase

# Opcional: bcrypt rounds (10-15, default 12).
PASSWORD_BCRYPT_ROUNDS = 12

# Opcional: migracion temporal de passwords legacy en texto plano.
ALLOW_LEGACY_PLAINTEXT_PASSWORD_LOGIN = false
