# ============================================================
backups/
*.bak
*.backup
*.tmp
*.temp
~$*

# ============================================================
# CI / DEPLOY
# ============================================================
nextgen_platform/ci_artifacts/

# ============================================================
# BASES DE DATOS LOCALES (NUNCA SUBIR DATOS DE PACIENTES)
# ============================================================
*.db
*.sqlite
*.sqlite3
local_data/
patient_data/

# ============================================================
# ARCHIVOS DE PRUEBA / DESCARGAS GENERADAS
# ============================================================
