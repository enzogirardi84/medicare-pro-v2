# Variables de entorno y secretos
.env
.env.example
.env.local
.env.*.local
.env.development
.env.production
*.pem
*.key
*.cert

# Caches de herramientas
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.cache/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# IDEs y editores
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.spyderproject
.spyproject
.ropeproject

# Jupyter / notebooks
.ipynb_checkpoints/
*.ipynb_checkpoints

# Node / npm
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.yarn/
package.json
package-lock.json

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

